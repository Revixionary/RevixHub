local function makeNavButton(text, icon)
	local btn = Instance.new("TextButton", ButtonList)
	btn.Size = UDim2.new(1, 0, 0, 32)
	btn.BackgroundColor3 = BG_MID
	btn.BorderSizePixel = 0
	makeCorner(btn, 5)

	local iconLabel = Instance.new("TextLabel", btn)
	iconLabel.Size = UDim2.new(0, 20, 1, 0)
	iconLabel.Position = UDim2.new(0, 8, 0, 0)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Text = icon or "›"
	iconLabel.Font = Enum.Font.GothamBold
	iconLabel.TextSize = 13
	iconLabel.TextColor3 = TEXT_MUTED
	iconLabel.TextXAlignment = Enum.TextXAlignment.Center

	local textLabel = Instance.new("TextLabel", btn)
	textLabel.Size = UDim2.new(1, -32, 1, 0)
	textLabel.Position = UDim2.new(0, 30, 0, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = text
	textLabel.Font = Enum.Font.Gotham
	textLabel.TextSize = 12
	textLabel.TextColor3 = TEXT_MUTED
	textLabel.TextXAlignment = Enum.TextXAlignment.Left

	local activeBar = Instance.new("Frame", btn)
	activeBar.Size = UDim2.new(0, 3, 0.6, 0)
	activeBar.Position = UDim2.new(0, 0, 0.2, 0)
	activeBar.BackgroundColor3 = ACCENT
	makeCorner(activeBar, 2)
	activeBar.Visible = false

	btn.MouseEnter:Connect(function()
		if textLabel.TextColor3 ~= TEXT_PRIMARY then
			tweenBgColor(btn, BG_BTN_HOV)
		end
	end)
	btn.MouseLeave:Connect(function()
		if textLabel.TextColor3 ~= TEXT_PRIMARY then
			tweenBgColor(btn, BG_MID)
		end
	end)

	return btn, textLabel, iconLabel, activeBar
end

