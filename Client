	aimLocking = true
	aimlockTarget = targetPlayer
	aimHighlight = Instance.new("Highlight")
	aimHighlight.FillColor = Color3.fromRGB(255, 50, 50)
	aimHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	aimHighlight.FillTransparency = 0.5
