local VALID_KEY_PREFIX = "RBH-"
local VALID_KEY_LENGTH = 16
local function validateKey(key)
    if type(key) ~= "string" then return false end
    if #key ~= VALID_KEY_LENGTH then return false end
    if key:sub(1, #VALID_KEY_PREFIX) ~= VALID_KEY_PREFIX then return false end
    local suffix = key:sub(#VALID_KEY_PREFIX + 1)
    local sum = 0
    for i = 1, #suffix do sum = sum + string.byte(suffix, i) end
    return (sum % 7) == 0
end
local function generateSampleKey()
    local chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"
    local suffix, attempt = "", 0
    repeat
        suffix = ""; attempt = attempt + 1
        local len = VALID_KEY_LENGTH - #VALID_KEY_PREFIX
        for _ = 1, len do local idx = math.random(1, #chars); suffix = suffix .. chars:sub(idx, idx) end
        local sum = 0; for i = 1, #suffix do sum = sum + string.byte(suffix, i) end
        if (sum % 7) == 0 then break end
    until attempt > 500
    return VALID_KEY_PREFIX .. suffix
end

