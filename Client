local function makeStroke(parent, thickness, color, mode)
	local s = Instance.new("UIStroke", parent)
	s.Thickness = thickness or 1
	s.Color = color or BORDER
	if mode then s.ApplyStrokeMode = mode end
	return s
end

local function makeCorner(parent, radius)
	local c = Instance.new("UICorner", parent)
	c.CornerRadius = UDim.new(0, radius or 6)
	return c
end

local function makePadding(parent, px)
	local p = Instance.new("UIPadding", parent)
	p.PaddingLeft = UDim.new(0, px)
	p.PaddingRight = UDim.new(0, px)
	p.PaddingTop = UDim.new(0, px)
	p.PaddingBottom = UDim.new(0, px)
	return p
end

local function tweenBgColor(obj, color, t)
	TweenService:Create(obj, TweenInfo.new(t or 0.15), {BackgroundColor3 = color}):Play()
end

local function addHoverEffect(btn, normalColor, hoverColor)
	btn.MouseEnter:Connect(function() tweenBgColor(btn, hoverColor) end)
	btn.MouseLeave:Connect(function() tweenBgColor(btn, normalColor) end)
end

