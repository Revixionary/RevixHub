-- ANTI RAGDOLL TAB
-- ══════════════════════════════════════════════════════════════════════════
do
    local antiRagEnabled = false
    local ragdollConn = nil
    local ragdollStateConn = nil
    local LocalRagdollEvent = nil
    local RagdollStateRemote = nil

    pcall(function() LocalRagdollEvent = ReplicatedStorage:WaitForChild("LocalRagdollEvent", 3) end)
    pcall(function()
        local ev = ReplicatedStorage:WaitForChild("Events", 3)
        if ev then RagdollStateRemote = ev:WaitForChild("RagdollState", 3) end
    end)

    local function enableAntiRag()
        antiRagEnabled = true
        -- Connect to LocalRagdollEvent to immediately snap back up when ragdoll fires
        if LocalRagdollEvent then
            pcall(function()
                ragdollConn = LocalRagdollEvent.Event:Connect(function(shouldRagdoll)
                    if antiRagEnabled and shouldRagdoll then
                        local ch = player.Character; if not ch then return end
                        local hum = ch:FindFirstChildOfClass("Humanoid")
                        local hrp = ch:FindFirstChild("HumanoidRootPart")
                        task.wait(0.05)
                        pcall(function() if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end end)
                        pcall(function() if hum then hum.AutoRotate = true end end)
                        pcall(function() if hrp then hrp.CanCollide = true end end)
                    end
                end)
            end)
        end
        -- Heartbeat loop: constantly kick out of Physics state
        ragdollStateConn = RunService.Heartbeat:Connect(function()
            if not antiRagEnabled then return end
            local ch = player.Character; if not ch then return end
            local hum = ch:FindFirstChildOfClass("Humanoid"); if not hum then return end
            if hum:GetState() == Enum.HumanoidStateType.Physics then
                local hrp = ch:FindFirstChild("HumanoidRootPart")
                pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
                pcall(function() hum.AutoRotate = true end)
                pcall(function() if hrp then hrp.CanCollide = true end end)
                if RagdollStateRemote then pcall(function() RagdollStateRemote:FireServer(false, false) end) end
            end
        end)
        setStatus("Anti Ragdoll ON", C.green)
    end

    local function disableAntiRag()
        antiRagEnabled = false
        if ragdollConn then ragdollConn:Disconnect(); ragdollConn = nil end
        if ragdollStateConn then ragdollStateConn:Disconnect(); ragdollStateConn = nil end
        setStatus("Anti Ragdoll OFF")
    end

    pSecLbl(AntiRagScroll, "ANTI RAGDOLL")
    pLabel(AntiRagScroll, "Prevents your character from entering ragdoll state. When enabled, any forced or voluntary ragdoll is immediately cancelled and you stand back up. Toggle off to ragdoll normally.", 52)
    pDivLine(AntiRagScroll)
    local ARBtn, ARDot = pBtn(AntiRagScroll, "Anti Ragdoll: OFF")
    local ARStatusLbl = pLabel(AntiRagScroll, "Status: Disabled", 18)

    ARBtn.MouseButton1Click:Connect(function()
        if antiRagEnabled then
            disableAntiRag()
            ARBtn.Text = "Anti Ragdoll: OFF"; ARDot.BackgroundColor3 = C.muted
            ARStatusLbl.Text = "Status: Disabled"; ARStatusLbl.TextColor3 = C.muted
        else
            enableAntiRag()
            ARBtn.Text = "Anti Ragdoll: ON"; ARDot.BackgroundColor3 = C.green
            ARStatusLbl.Text = "Status: Active — ragdoll blocked"; ARStatusLbl.TextColor3 = C.green
        end
    end)

    pDivLine(AntiRagScroll)
    pLabel(AntiRagScroll, "Note: works by constantly resetting humanoid state out of Physics mode. May conflict with games that use ragdoll for death animations.", 36, C.muted)

    -- Reconnect cleanly on respawn
    player.CharacterAdded:Connect(function()
        if antiRagEnabled then
            if ragdollConn then ragdollConn:Disconnect(); ragdollConn = nil end
            if ragdollStateConn then ragdollStateConn:Disconnect(); ragdollStateConn = nil end
            task.wait(1); enableAntiRag()
        end
    end)
end

