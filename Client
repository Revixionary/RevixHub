local function startTpWalk()
	local speed = tonumber(TpWalkAmountBox.Text) or 4
	tpwalking = true
	TpWalkToggleBtn.Text = "TpWalk [ON]"
	TpWalkStatusDot.BackgroundColor3 = GREEN
	local char = player.Character
	local hum = char and char:FindFirstChildWhichIsA("Humanoid")
	if not hum then stopTpWalk() return end
	task.spawn(function()
		while tpwalking and char and hum and hum.Parent do
			local delta = RunService.Heartbeat:Wait()
			if hum.MoveDirection.Magnitude > 0 then
				local s = tonumber(TpWalkAmountBox.Text) or speed
				pcall(function() char:TranslateBy(hum.MoveDirection * s * delta * 10) end)
			end
			if not player.Character or player.Character ~= char then stopTpWalk() end
		end
	end)
	setStatus("TpWalk at speed " .. tostring(speed), GREEN)
end

