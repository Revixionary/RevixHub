-- =====================
-- MOUSE UNLOCK LOGIC
-- =====================

local mouseUnlocked = false
local mouseUnlockConnection = nil

local function stopMouseUnlock()
	mouseUnlocked = false
	MouseUnlock.Text = "MouseUnlock"
	if mouseUnlockConnection then
		mouseUnlockConnection:Disconnect()
		mouseUnlockConnection = nil
	end
end

local function startMouseUnlock()
	mouseUnlocked = true
	MouseUnlock.Text = "MouseUnlock [ON]"
	mouseUnlockConnection = RunService.RenderStepped:Connect(function()
		UIS.MouseBehavior = Enum.MouseBehavior.Default
	end)
end

MouseUnlock.MouseButton1Click:Connect(function()
	if mouseUnlocked then
		stopMouseUnlock()
	else
		startMouseUnlock()
	end
end)

-- =====================
-- AIMLOCK LOGIC
-- =====================

local aimLocking = false
local aimlockTarget = nil
local aimlockConnection = nil
local highlight = nil

local function removeHighlight()
	if highlight then
		highlight:Destroy()
		highlight = nil
	end
end

local function stopAimlock()
	aimLocking = false
	if aimlockConnection then
		aimlockConnection:Disconnect()
		aimlockConnection = nil
	end
	removeHighlight()
	aimlockTarget = nil
end

local function startAimlock(targetPlayer)
	if aimLocking and aimlockTarget == targetPlayer then
		stopAimlock()
		return
	end

	stopAimlock()

	local char = targetPlayer.Character
	if not char then return end

	aimLocking = true
	aimlockTarget = targetPlayer

	highlight = Instance.new("Highlight")
	highlight.FillColor = Color3.fromRGB(255, 0, 0)
	highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	highlight.FillTransparency = 0.5
	highlight.Parent = char

	aimlockConnection = RunService.RenderStepped:Connect(function()
		local tChar = aimlockTarget and aimlockTarget.Character
		if not tChar or not tChar:FindFirstChild("HumanoidRootPart") then
			stopAimlock()
			return
		end
		local cam = workspace.CurrentCamera
		cam.CFrame = CFrame.new(cam.CFrame.Position, tChar.HumanoidRootPart.Position)
	end)
end

Players.PlayerRemoving:Connect(function(plr)
	if aimlockTarget == plr then stopAimlock() end
end)

-- =====================
-- FLY LOGIC
-- =====================

local flying = false
local flyBV = nil
local flyBG = nil
local flyConnection = nil

local function stopFly()
	flying = false
	if flyBV then flyBV:Destroy(); flyBV = nil end
	if flyBG then flyBG:Destroy(); flyBG = nil end
	if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
	Fly.Text = "Fly"
end

local function startFly()
	local speed = tonumber(AmountTextBox.Text) or 70
	local char = player.Character or player.CharacterAdded:Wait()
	local root = char:WaitForChild("HumanoidRootPart")

	flying = true
	Fly.Text = "Fly [ON]"

	flyBV = Instance.new("BodyVelocity")
	flyBV.MaxForce = Vector3.new(1, 1, 1) * 100000
	flyBV.Parent = root

	flyBG = Instance.new("BodyGyro")
	flyBG.MaxTorque = Vector3.new(1, 1, 1) * 100000
	flyBG.CFrame = root.CFrame
	flyBG.Parent = root

	flyConnection = RunService.RenderStepped:Connect(function()
		if flying and root and root.Parent then
			local cam = workspace.CurrentCamera
			local currentSpeed = tonumber(AmountTextBox.Text) or speed
			flyBV.Velocity = cam.CFrame.LookVector * currentSpeed
			flyBG.CFrame = cam.CFrame
		end
	end)
end

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.E and Currentselected.Text == "Current Selected: Fly" then
		if flying then stopFly() else startFly() end
	end
end)

player.CharacterAdded:Connect(function()
	if flying then stopFly() end
end)

-- =====================
-- TPWALK LOGIC
-- =====================

local tpwalking = false

local function stopTpWalk()
	tpwalking = false
	TpWalk.Text = "TpWalk"
end

local function startTpWalk()
	local speed = tonumber(AmountTextBox.Text) or 4
	tpwalking = true
	TpWalk.Text = "TpWalk [ON]"

	local char = player.Character
	local hum = char and char:FindFirstChildWhichIsA("Humanoid")
	if not hum then stopTpWalk() return end

	task.spawn(function()
		while tpwalking and char and hum and hum.Parent do
			local delta = RunService.Heartbeat:Wait()
			if hum.MoveDirection.Magnitude > 0 then
				local currentSpeed = tonumber(AmountTextBox.Text) or speed
				pcall(function()
					char:TranslateBy(hum.MoveDirection * currentSpeed * delta * 10)
				end)
			end
			if not player.Character or player.Character ~= char then
				stopTpWalk()
			end
		end
	end)
end

player.CharacterAdded:Connect(function()
	if tpwalking then stopTpWalk() end
end)

-- =====================
-- PLAYER LIST
-- =====================

local playerButtons = {}

local function updateCanvas()
	ScrollingList.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end

local function createPlayerButton(targetPlayer)
	if targetPlayer == player then return end

	local btn = TemplatePlayer:Clone()
	btn.Text = targetPlayer.Name
	btn.Visible = true
	btn.Parent = ScrollingList

	btn.MouseButton1Click:Connect(function()
		CurrentSelectedPlayer.Text = "Current Selected Player: " .. targetPlayer.Name

		local feature = Currentselected.Text

		if feature == "Current Selected: TP" then
			local char = player.Character
			local targetChar = targetPlayer.Character
			if char and targetChar then
				local root = char:FindFirstChild("HumanoidRootPart")
				local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
				if root and targetRoot then
					root.CFrame = targetRoot.CFrame + Vector3.new(2, 0, 0)
				end
			end

		elseif feature == "Current Selected: Aimlock" then
			startAimlock(targetPlayer)
		end
	end)

	playerButtons[targetPlayer] = btn
	updateCanvas()
end

for _, plr in pairs(Players:GetPlayers()) do
	createPlayerButton(plr)
end

Players.PlayerAdded:Connect(createPlayerButton)

Players.PlayerRemoving:Connect(function(plr)
	if playerButtons[plr] then
		playerButtons[plr]:Destroy()
		playerButtons[plr] = nil
		updateCanvas()
	end
end)

UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

-- =====================
-- FEATURE SELECTION
-- =====================

local currentFeature = nil

local function selectFeature(featureName, showPlayerList, showAmount)
	if currentFeature == featureName then
		currentFeature = nil
		Currentselected.Text = "Current Selected: None"
		PlayerList.Visible = false
		AmountTextBox.Visible = false
		CurrentSelectedPlayer.Text = "Current Selected Player: None"
		if featureName == "Aimlock" then stopAimlock() end
		if featureName == "Fly" then stopFly() end
		if featureName == "TpWalk" then stopTpWalk() end
		return
	end

	if currentFeature == "Aimlock" then stopAimlock() end
	if currentFeature == "Fly" then stopFly() end
	if currentFeature == "TpWalk" then stopTpWalk() end

	currentFeature = featureName
	Currentselected.Text = "Current Selected: " .. featureName
	PlayerList.Visible = showPlayerList
	AmountTextBox.Visible = showAmount

	if not showPlayerList then
		CurrentSelectedPlayer.Text = "Current Selected Player: None"
	end
end

Tp.MouseButton1Click:Connect(function()
	selectFeature("TP", true, false)
end)

Aimlock.MouseButton1Click:Connect(function()
	selectFeature("Aimlock", true, false)
end)

Fly.MouseButton1Click:Connect(function()
	selectFeature("Fly", false, true)
	if currentFeature == "Fly" then
		if flying then stopFly() else startFly() end
	end
end)

TpWalk.MouseButton1Click:Connect(function()
	selectFeature("TpWalk", false, true)
	if currentFeature == "TpWalk" then
		if tpwalking then stopTpWalk() else startTpWalk() end
	end
end)
