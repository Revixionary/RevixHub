local playerButtons = {}

local function updateCanvas()
	ScrollingList.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end

local function createPlayerButton(targetPlayer)
	if targetPlayer == player then return end
	local btn = TemplatePlayer:Clone()
	btn.Text = targetPlayer.Name
	btn.Visible = true
	btn.Parent = ScrollingList
	addHoverEffect(btn, BG_BTN, BG_BTN_HOV)

	btn.MouseButton1Click:Connect(function()
		CurrentSelectedPlayer.Text = targetPlayer.Name

		if activeNavItem == navItems[1] then
			local char = player.Character
			local targetChar = targetPlayer.Character
			if char and targetChar then
				local root = char:FindFirstChild("HumanoidRootPart")
				local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
				if root and targetRoot then
					root.CFrame = targetRoot.CFrame + Vector3.new(2, 0, 0)
					setStatus("Teleported to " .. targetPlayer.Name, GREEN)
				end
			end
		elseif activeNavItem == navItems[2] then
			startAimlock(targetPlayer)
		end
	end)

	playerButtons[targetPlayer] = btn
	updateCanvas()
end

for _, plr in pairs(Players:GetPlayers()) do createPlayerButton(plr) end
Players.PlayerAdded:Connect(createPlayerButton)
Players.PlayerRemoving:Connect(function(plr)
	if playerButtons[plr] then
		playerButtons[plr]:Destroy()
		playerButtons[plr] = nil
		updateCanvas()
	end
end)
UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

local function shouldShowPlayerList()
	return activeNavItem == navItems[1] or activeNavItem == navItems[2]
end

for _, item in ipairs(navItems) do
	local capturedItem = item
	item.btn.MouseButton1Click:Connect(function()
		PlayerList.Visible = shouldShowPlayerList()
		ColorPanel.Visible = false
		ColorOpenDot.BackgroundColor3 = TEXT_MUTED
		ColorOpenBtn.Text = "Open Color Panel"
	end)
end

TpNavBtn.MouseButton1Click:Connect(function() PlayerList.Visible = true end)
AimNavBtn.MouseButton1Click:Connect(function() PlayerList.Visible = true end)
FlyNavBtn.MouseButton1Click:Connect(function() PlayerList.Visible = false end)
TpWalkNavBtn.MouseButton1Click:Connect(function() PlayerList.Visible = false end)
MouseNavBtn.MouseButton1Click:Connect(function() PlayerList.Visible = false end)
ColorNavBtn.MouseButton1Click:Connect(function() PlayerList.Visible = false end)
