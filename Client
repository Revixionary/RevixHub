local ColorRemote, NameRemote, BioColorRemote, isBioFunction
pcall(function()
	local Remotes = ReplicatedStorage:WaitForChild("Remotes", 3)
	if Remotes then
		ColorRemote = Remotes:FindFirstChild("UpdateRPColor")
		NameRemote = Remotes:FindFirstChild("UpdateRPName")
		BioColorRemote = Remotes:FindFirstChild("UpdateBioColor")
		if BioColorRemote then isBioFunction = BioColorRemote:IsA("RemoteFunction") end
	end
end)

local function fireColorRemote(color)
	if ColorRemote then pcall(function() ColorRemote:FireServer(color) end) end
end
local function fireBioRemote(color)
	if BioColorRemote then
		pcall(function()
			if isBioFunction then BioColorRemote:InvokeServer(color) else BioColorRemote:FireServer(color) end
		end)
	end
end
local function fireNameRemote(text)
	if NameRemote then pcall(function() NameRemote:FireServer(text) end) end
end
local function fireGradientRemote(seq, rot)
	if GradientRemote then pcall(function() GradientRemote:FireServer(seq, rot) end) end
end

local function stopColor()
	colorRunning = false
	if colorConnection then colorConnection:Disconnect(); colorConnection = nil end
	if gradientRotationConnection then gradientRotationConnection:Disconnect(); gradientRotationConnection = nil end
	ColorStartBtn.Text = "START"
	ColorStartBtn.BackgroundColor3 = ACCENT
	setStatus("Color stopped", TEXT_MUTED)
end

local function startColor()
	colorRunning = true
	colorTime = 0
	colorCharCount = 1
	lastNameUpdate = 0
	lastBioUpdate = 0
	gradientRotation = 0
	local word = RPNameBox.Text ~= "" and RPNameBox.Text or (player.DisplayName or player.Name)
	ColorStartBtn.Text = "STOP"
	ColorStartBtn.BackgroundColor3 = RED
	setStatus("Color running", GREEN)

	colorConnection = RunService.Heartbeat:Connect(function(dt)
		colorTime += dt * colorCycleSpeed
		local cycledH = (pickedH + colorTime * 0.1) % 1
		local color = Color3.fromHSV(cycledH, pickedS, pickedV)

		if gradientEnabled then
			if rotationEnabled then
				gradientRotation = (gradientRotation + dt * colorCycleSpeed * 30) % 360
			end
			fireGradientRemote(buildColorSequence(), rotationEnabled and gradientRotation or 0)
		end

		fireColorRemote(color)

		lastBioUpdate += dt
		if lastBioUpdate >= bioUpdateFreq then
			lastBioUpdate = 0
			fireBioRemote(color)
		end

		lastNameUpdate += dt
		if lastNameUpdate >= nameUpdateFreq then
			lastNameUpdate = 0
			local text = string.sub(word, 1, colorCharCount)
			fireNameRemote(text)
			colorCharCount = (colorCharCount >= #word) and 1 or (colorCharCount + 1)
		end
	end)
end

ColorStartBtn.MouseButton1Click:Connect(function()
	if colorRunning then stopColor() else startColor() end
end)

