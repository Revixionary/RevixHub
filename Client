    end)
    local bgVisible=true
    BgBtn.MouseButton1Click:Connect(function() bgVisible=not bgVisible; BGImg.Visible=bgVisible; if bgVisible then BgBtn.Text="Background Image: ON"; BgDot.BackgroundColor3=C.green else BgBtn.Text="Background Image: OFF"; BgDot.BackgroundColor3=C.muted end end)
end

