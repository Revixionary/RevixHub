end)

local function fireColorRemote(color)
	if ColorRemote then pcall(function() ColorRemote:FireServer(color) end) end
end
local function fireBioRemote(color)
	if BioColorRemote then
		pcall(function()
			if isBioFunction then BioColorRemote:InvokeServer(color) else BioColorRemote:FireServer(color) end
		end)
	end
end
local function fireNameRemote(text)
	if NameRemote then pcall(function() NameRemote:FireServer(text) end) end
end

local function stopColor()
	colorRunning = false
	if colorConnection then colorConnection:Disconnect(); colorConnection = nil end
	ColorStartBtn.Text = "Start"
	ColorBtn.Text = "Color"
end

local function startColor()
	colorRunning = true
	colorTime = 0
	colorCharCount = 1
	lastNameUpdate = 0
	lastBioUpdate = 0
	colorWord = RPNameBox.Text ~= "" and RPNameBox.Text or (player.DisplayName or player.Name)
	ColorStartBtn.Text = "Stop"
	ColorBtn.Text = "Color [ON]"

	colorConnection = RunService.Heartbeat:Connect(function(dt)
		colorTime += dt * colorCycleSpeed

		-- Cycle hue from picked H, keeping S and V from picker
		local cycledH = (pickedH + colorTime * 0.1) % 1
		local color = Color3.fromHSV(cycledH, pickedS, pickedV)

		fireColorRemote(color)

		lastBioUpdate += dt
		if lastBioUpdate >= bioUpdateFreq then
			lastBioUpdate = 0
			fireBioRemote(color)
		end

		lastNameUpdate += dt
		if lastNameUpdate >= nameUpdateFreq then
			lastNameUpdate = 0
			local text = string.sub(colorWord, 1, colorCharCount)
			fireNameRemote(text)
			colorCharCount = (colorCharCount >= #colorWord) and 1 or (colorCharCount + 1)
		end
	end)
end

ColorStartBtn.MouseButton1Click:Connect(function()
	if colorRunning then stopColor() else startColor() end
end)

-- =====================
-- PLAYER LIST
-- =====================

local playerButtons = {}

local function updateCanvas()
	ScrollingList.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end

local function createPlayerButton(targetPlayer)
	if targetPlayer == player then return end
	local btn = TemplatePlayer:Clone()
	btn.Text = targetPlayer.Name
	btn.Visible = true
	btn.Parent = ScrollingList
	btn.MouseButton1Click:Connect(function()
		CurrentSelectedPlayer.Text = "Current Selected Player: " .. targetPlayer.Name
		local feature = Currentselected.Text
		if feature == "Current Selected: TP" then
			local char = player.Character
			local targetChar = targetPlayer.Character
			if char and targetChar then
				local root = char:FindFirstChild("HumanoidRootPart")
				local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
				if root and targetRoot then
					root.CFrame = targetRoot.CFrame + Vector3.new(2, 0, 0)
				end
			end
		elseif feature == "Current Selected: Aimlock" then
			startAimlock(targetPlayer)
		end
	end)
	playerButtons[targetPlayer] = btn
	updateCanvas()
end

for _, plr in pairs(Players:GetPlayers()) do createPlayerButton(plr) end
Players.PlayerAdded:Connect(createPlayerButton)
Players.PlayerRemoving:Connect(function(plr)
	if playerButtons[plr] then
		playerButtons[plr]:Destroy()
		playerButtons[plr] = nil
		updateCanvas()
	end
end)
UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

-- =====================
-- FEATURE SELECTION
-- =====================

local currentFeature = nil

local function selectFeature(featureName, showPlayerList, showAmount, showColorPanel)
	-- Toggle off same feature
	if currentFeature == featureName then
		currentFeature = nil
		Currentselected.Text = "Current Selected: None"
		PlayerList.Visible = false
		AmountTextBox.Visible = false
		ColorPanel.Visible = false
		CurrentSelectedPlayer.Text = "Current Selected Player: None"
		if featureName == "Aimlock" then stopAimlock() end
		if featureName == "Fly" then stopFly() end
		if featureName == "TpWalk" then stopTpWalk() end
		if featureName == "Color" then stopColor() end
		return
	end

	-- Stop old features when switching
	if currentFeature == "Aimlock" then stopAimlock() end
	if currentFeature == "Fly" then stopFly() end
	if currentFeature == "TpWalk" then stopTpWalk() end
	if currentFeature == "Color" then stopColor() end

	currentFeature = featureName
	Currentselected.Text = "Current Selected: " .. featureName
	PlayerList.Visible = showPlayerList or false
	AmountTextBox.Visible = showAmount or false
	ColorPanel.Visible = showColorPanel or false

	if not showPlayerList then
		CurrentSelectedPlayer.Text = "Current Selected Player: None"
	end
end

Tp.MouseButton1Click:Connect(function()
	selectFeature("TP", true, false, false)
end)

Aimlock.MouseButton1Click:Connect(function()
	selectFeature("Aimlock", true, false, false)
end)

Fly.MouseButton1Click:Connect(function()
	selectFeature("Fly", false, true, false)
	if currentFeature == "Fly" then
		if flying then stopFly() else startFly() end
	end
end)

TpWalk.MouseButton1Click:Connect(function()
	selectFeature("TpWalk", false, true, false)
	if currentFeature == "TpWalk" then
		if tpwalking then stopTpWalk() else startTpWalk() end
	end
end)

ColorBtn.MouseButton1Click:Connect(function()
	selectFeature("Color", false, false, true)
end)
