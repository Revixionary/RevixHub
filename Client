local function buildColorSequence()
	local kps = {}
	for _, kp in ipairs(keypoints) do
		table.insert(kps, ColorSequenceKeypoint.new(math.clamp(kp.pos, 0, 1), kp.color))
	end
	table.sort(kps, function(a, b) return a.Time < b.Time end)
	return ColorSequence.new(kps)
end

local function colorFromHex(hex)
	hex = hex:gsub("#", "")
	if #hex ~= 6 then return Color3.new(1, 1, 1) end
	local r = tonumber(hex:sub(1,2), 16) or 255
	local g = tonumber(hex:sub(3,4), 16) or 255
	local b = tonumber(hex:sub(5,6), 16) or 255
	return Color3.fromRGB(r, g, b)
end

local function hexFromColor(color)
	local function h(n) return string.format("%02X", math.floor(n * 255)) end
	return h(color.R) .. h(color.G) .. h(color.B)
end

